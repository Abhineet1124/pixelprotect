generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}



model User {

  id String @id @default(uuid())

  firstName String?

  lastName String?

  email String @unique

  passwordHash String

  riskScore Int @default(0)

  createdAt DateTime @default(now())

}

model ActivityLog {

  id String @id @default(uuid())

  action String

  details String?

  ipAddress String?

  device String?

  createdAt DateTime @default(now())

}

model File {

  id String @id @default(uuid())

  filename String

  encryptedName String

  size Int

  createdAt DateTime @default(now())

}
model ThreatLog {

  id String @id @default(uuid())

  type String

  severity String

  description String

  riskScore Int

  status String @default("ACTIVE")

  createdAt DateTime @default(now())

}